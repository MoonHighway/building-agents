# Vercel AI Gateway, one key, every model.
# Get yours: https://vercel.com/dashboard → AI Gateway → API Keys
AI_GATEWAY_API_KEY=vck_your_key_here

# Twilio SMS (needed for 10-sms-agent.ts)
# Get these from https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM=+15551234567   # your Twilio phone number
TWILIO_TO=+15559876543     # your personal phone number
